{
  "name": "rust-dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/workspace",
  "mounts": [
    "source=${localWorkspaceFolder},target=/workspace,type=bind"
  ],
  "customizations": {
    "jetbrains": {
      "backend": "Docker"
    }
  },
  "remoteUser": "root"
}
